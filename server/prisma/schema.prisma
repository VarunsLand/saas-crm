generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum InteractionType {
  CALL
  WHATSAPP
  EMAIL
  MEETING
  WALK_IN
  NOTE
  STATUS_CHANGE
}

enum TaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Tenant {
  id         String       @id @default(uuid()) @db.Uuid
  name       String       @db.VarChar(255)
  industry   String?      @db.VarChar(100)
  timezone   String       @default("UTC") @db.VarChar(50)
  status     TenantStatus @default(ACTIVE)
  created_at DateTime     @default(now()) @db.Timestamptz
  updated_at DateTime     @updatedAt @db.Timestamptz
  deleted_at DateTime?    @db.Timestamptz

  users           User[]
  leads           Lead[]
  lead_sources    LeadSource[]
  interactions    Interaction[]
  follow_up_tasks FollowUpTask[]
  audit_logs      AuditLog[]
  customers       Customer[]
  revenue_entries RevenueEntry[]
  expense_entries ExpenseEntry[]

  @@map("tenants")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  tenant_id     String    @db.Uuid
  email         String    @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  first_name    String    @db.VarChar(100)
  last_name     String    @db.VarChar(100)
  role          UserRole  @default(STAFF)
  last_login_at          DateTime? @db.Timestamptz
  reset_password_token   String?   @db.VarChar(255)
  reset_password_expires DateTime? @db.Timestamptz
  created_at             DateTime  @default(now()) @db.Timestamptz
  updated_at             DateTime  @updatedAt @db.Timestamptz
  deleted_at             DateTime? @db.Timestamptz

  tenant         Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  assigned_leads Lead[]
  customers      Customer[]
  interactions   Interaction[]
  tasks          FollowUpTask[]
  audit_logs     AuditLog[]

  @@unique([tenant_id, email])
  @@index([tenant_id, email])
  @@map("users")
}

model LeadSource {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  name       String   @db.VarChar(100)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  leads  Lead[]

  @@index([tenant_id, is_active])
  @@map("lead_sources")
}

model Lead {
  id           String     @id @default(uuid()) @db.Uuid
  tenant_id    String     @db.Uuid
  source_id    String?    @db.Uuid
  assigned_to  String?    @db.Uuid
  first_name   String     @db.VarChar(100)
  last_name    String?    @db.VarChar(100)
  phone_number String     @db.VarChar(50)
  email        String?    @db.VarChar(255)
  service      String?    @db.VarChar(255)
  description  String?    @db.Text
  status       LeadStatus @default(NEW)
  converted_to_customer_id String? @db.Uuid
  created_at   DateTime   @default(now()) @db.Timestamptz
  updated_at   DateTime   @updatedAt @db.Timestamptz
  deleted_at   DateTime?  @db.Timestamptz

  tenant       Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  source       LeadSource?    @relation(fields: [source_id], references: [id], onDelete: SetNull)
  assignee     User?          @relation(fields: [assigned_to], references: [id], onDelete: SetNull)
  interactions Interaction[]
  tasks        FollowUpTask[]

  @@index([tenant_id, phone_number])
  @@index([tenant_id, status])
  @@index([tenant_id, assigned_to])
  @@map("leads")
}

model Interaction {
  id          String          @id @default(uuid()) @db.Uuid
  tenant_id   String          @db.Uuid
  lead_id     String?         @db.Uuid
  customer_id String?         @db.Uuid
  user_id     String?         @db.Uuid
  type        InteractionType
  title       String?         @db.VarChar(255)
  notes       String?         @db.Text
  created_at  DateTime        @default(now()) @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, lead_id, created_at(sort: Desc)])
  @@index([tenant_id, customer_id, created_at(sort: Desc)])
  @@map("interactions")
}

model FollowUpTask {
  id           String     @id @default(uuid()) @db.Uuid
  tenant_id    String     @db.Uuid
  lead_id      String?    @db.Uuid
  customer_id  String?    @db.Uuid
  assigned_to  String     @db.Uuid
  title        String     @default("Follow up") @db.VarChar(255)
  description  String?    @db.Text
  priority     String     @default("MEDIUM") @db.VarChar(20)
  due_date     DateTime   @db.Timestamptz
  status       TaskStatus @default(PENDING)
  completed_at DateTime?  @db.Timestamptz
  created_at   DateTime   @default(now()) @db.Timestamptz
  updated_at   DateTime   @updatedAt @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  assignee User      @relation(fields: [assigned_to], references: [id], onDelete: Cascade)

  @@index([tenant_id, assigned_to, due_date])
  @@index([tenant_id, lead_id])
  @@index([tenant_id, customer_id])
  @@map("follow_up_tasks")
}

model Customer {
  id           String     @id @default(uuid()) @db.Uuid
  tenant_id    String     @db.Uuid
  first_name   String     @db.VarChar(100)
  last_name    String?    @db.VarChar(100)
  company      String?    @db.VarChar(255)
  email        String?    @db.VarChar(255)
  phone_number String     @db.VarChar(50)
  total_revenue Float?    @default(0)
  assigned_to  String?    @db.Uuid
  created_at   DateTime   @default(now()) @db.Timestamptz
  updated_at   DateTime   @updatedAt @db.Timestamptz
  deleted_at   DateTime?  @db.Timestamptz

  tenant       Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  assignee     User?      @relation(fields: [assigned_to], references: [id], onDelete: SetNull)
  revenue_entries RevenueEntry[]
  interactions Interaction[]
  tasks        FollowUpTask[]

  @@index([tenant_id, email])
  @@index([tenant_id, phone_number])
  @@index([tenant_id, assigned_to])
  @@map("customers")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenant_id     String   @db.Uuid
  user_id       String?  @db.Uuid
  action        String   @db.VarChar(255)
  entity_type   String   @db.VarChar(100)
  entity_id     String   @db.Uuid
  previous_data Json?
  new_data      Json?
  ip_address    String?  @db.VarChar(45)
  created_at    DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, created_at(sort: Desc)])
  @@index([tenant_id, entity_type, entity_id])
  @@map("audit_logs")
}

model RevenueEntry {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_id   String   @db.Uuid
  customer_id String?  @db.Uuid
  amount      Float
  description String   @db.VarChar(255)
  date        DateTime @db.Timestamptz
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customer_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, date(sort: Desc)])
  @@map("revenue_entries")
}

model ExpenseEntry {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_id   String   @db.Uuid
  category    String   @db.VarChar(100)
  amount      Float
  description String   @db.VarChar(255)
  date        DateTime @db.Timestamptz
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, date(sort: Desc)])
  @@map("expense_entries")
}
